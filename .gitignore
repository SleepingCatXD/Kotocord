# === C++ / Visual Studio / CMake 临时文件 ===
.vs/
.vscode/
out/
build/
bin/
CMakeSettings.json
*.user
launch.vs.json
.editorconfig
CMakeCache.txt

# 忽略个人的机器路径配置
CMakePresets.json
CMakeUserPresets.json
VSCODE_DEV_GUIDE.md

# ==========================================
# Qt 自动化生成的中间文件
# ==========================================
*_autogen/
moc_*.cpp
ui_*.h
qrc_*.cpp
*.moc

# ==========================================
# 操作系统缓存文件
# ==========================================
Thumbs.db
.DS_Store

# === 第三方库的体积巨大文件 (非常重要) ===
# 只上传 third_party 里的头文件(.h)，不上传库文件，让用户自己去下载
third_party/**/*.dll
third_party/**/*.lib
third_party/**/*.a
third_party/**/*.so

# === 语音模型文件 (绝对不能上传) ===
resources/model/
*.wav
*.mp3